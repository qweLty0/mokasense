# MokaSense ortam değişkenleri örneği — gerçek değerler .env.local dosyasına yazılır (asla commit edilmez)

# Dil Katmanı — Claude API (P3)
ANTHROPIC_API_KEY=

# Aksiyon Katmanı — Moka (P4)
# MOKA_MODE=mock  -> canlı sunucuya gitmez, gerçek şema formatında istek üretir,
#                    gerçekçi başarı + tıklanabilir demo linki döner (varsayılan).
# MOKA_MODE=live  -> service.mokaunited.com'a gerçek POST atar (kod hazır).
MOKA_MODE=mock

# Live mod için Moka bayi bilgileri (CheckKey koddan üretilir)
MOKA_BASE_URL=https://service.mokaunited.com
MOKA_DEALER_CODE=
MOKA_USERNAME=
MOKA_PASSWORD=
